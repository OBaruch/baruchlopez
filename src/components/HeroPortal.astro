---
import type { GatewayItem } from "@/data/portal";

interface Props {
  gateways: GatewayItem[];
}

const { gateways } = Astro.props as Props;
---

<section class="hero-shell" id="top">
  <div class="content-shell">
    <div class="hero-panel">
      <div class="hero-main">
        <div class="hero-copy">
          <div class="hero-badge">
            <span class="dot"></span>
            BARUCHLOPEZ.COM / CENTRAL IDENTITY PORTAL
          </div>

          <h1 class="hero-title">
            Baruch Lopez
            <br />
            <em>AI, systems, and capital.</em>
          </h1>

          <p class="hero-subline">
            Artificial intelligence, strategic systems, and long-term capital vision.
          </p>
          <p class="hero-lead">
            Technology and finance are tools. The mission is human progress.
          </p>
          <p class="hero-text">
            A curated gateway into my ventures, corporate background, selected work, and
            long-term direction.
          </p>
        </div>

        <figure class="hero-portrait">
          <img
            class="hero-portrait-image"
            src="/assets/images/baruch-lopez-portrait.jpg"
            alt="Baruch Lopez portrait in a dark, cinematic setting."
            width="720"
            height="960"
            loading="eager"
            decoding="async"
          />
        </figure>
      </div>

      <div class="gateway-panel" id="gateways">
        <div class="gateway-heading">
          <span class="eyebrow">Core Domains</span>
          <p>Four domains, one central identity.</p>
        </div>

        <div class="gateway-grid">
          {
            gateways.map((gateway) => (
              <a class="gateway-card" href={gateway.href}>
                <div class="gateway-thumb">
                  <img
                    src={gateway.image}
                    alt=""
                    width="144"
                    height="144"
                    loading="lazy"
                    decoding="async"
                  />
                </div>

                <div class="gateway-copy">
                  <span class="mini-label">{gateway.label}</span>
                  <h2 class="gateway-title">{gateway.title}</h2>
                  <p class="gateway-summary">{gateway.summary}</p>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
