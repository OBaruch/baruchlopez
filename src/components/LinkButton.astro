---
import type { ActionLink } from "@/data/site";

interface Props extends ActionLink {
  className?: string;
}

const {
  label,
  href = null,
  variant = "primary",
  external = false,
  size = "default",
  className = "",
} = Astro.props as Props;

const classes = ["button-link", `button-link-${variant}`, size === "large" ? "button-link-large" : "", className]
  .filter(Boolean)
  .join(" ");
---

{
  href ? (
    <a
      class={classes}
      href={href}
      target={external ? "_blank" : undefined}
      rel={external ? "noopener noreferrer" : undefined}
    >
      <span>{label}</span>
    </a>
  ) : (
    <span class={`${classes} button-link-disabled`} aria-disabled="true">
      <span>{label}</span>
    </span>
  )
}
