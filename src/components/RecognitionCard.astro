---
import type { RecognitionItem } from "@/data/recognitions";

interface Props {
  item: RecognitionItem;
  compact?: boolean;
}

const { item, compact = false } = Astro.props as Props;
const sortDate = item.sort_date ?? (item.year ? `${item.year}-01-01` : "0000-00-00");
const yearValue = item.year ? String(item.year) : "";
const dateLabel = item.date_visible || yearValue;
const issuerLabel = item.institution || item.issuer || "";
const titleLabel = item.title || "";
const cardTitle = titleLabel || item.document_type || item.category_primary || "";
const description = item.description_short || item.description_expanded || "";
const imageAlt = titleLabel
  ? `Vista previa de ${titleLabel}${issuerLabel ? `, ${issuerLabel}` : ""}.`
  : "Vista previa de documento del mural.";
const tags = [...new Set([item.category_primary, item.category_secondary, item.life_stage, ...item.tags].filter(Boolean))];
const topicsLabel = item.skills_or_topics.join(", ");
const detailRows = [
  ["Fecha", dateLabel],
  ["Institución", item.institution],
  ["Emisor", item.issuer && item.issuer !== item.institution ? item.issuer : ""],
  ["Programa", item.issuing_department_or_program],
  ["Plataforma", item.credential_platform],
  ["Tipo", item.document_type],
  ["Área", item.category_primary],
  ["Área secundaria", item.category_secondary],
  ["Etapa", item.life_stage],
  ["Temas", topicsLabel],
].filter(([, value]) => Boolean(value));
---

<article
  class:list={["recognition-card", "panel", "reveal-enter", compact ? "recognition-card-compact" : ""]}
  data-recognition-card
  data-title={titleLabel.toLowerCase()}
  data-year={yearValue}
  data-type={item.document_type}
  data-category={item.category_primary}
  data-life-stage={item.life_stage}
  data-institution={issuerLabel}
  data-issuer={item.issuer_group || issuerLabel}
  data-topics={topicsLabel}
  data-date={sortDate}
>
  <div class="recognition-media">
    {
      item.display_image ? (
        <img src={item.display_image} alt={imageAlt} loading="lazy" decoding="async" />
      ) : (
        <div class="recognition-placeholder" aria-label={imageAlt}>
          {item.document_type ? <span>{item.document_type}</span> : null}
          {dateLabel ? <strong>{dateLabel}</strong> : null}
        </div>
      )
    }
  </div>
  <div class="recognition-copy">
    {
      item.document_type || dateLabel ? (
        <div class="recognition-topline">
          {item.document_type ? <span class="mini-label">{item.document_type}</span> : null}
          {dateLabel ? <span class="project-year">{dateLabel}</span> : null}
        </div>
      ) : null
    }
    {cardTitle ? <h3>{cardTitle}</h3> : null}
    {issuerLabel ? <p class="issuer-line">{issuerLabel}</p> : null}
    {description ? <p>{description}</p> : null}
    {
      tags.length ? (
        <div class="tag-list recognition-tags" aria-label={titleLabel ? `Categorías de ${titleLabel}` : "Categorías del documento"}>
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      ) : null
    }
    {
      compact || !detailRows.length ? null : (
        <details class="recognition-detail">
          <summary>Ver detalle</summary>
          <dl>
            {
              detailRows.map(([label, value]) => (
                <div>
                  <dt>{label}</dt>
                  <dd>{value}</dd>
                </div>
              ))
            }
          </dl>
        </details>
      )
    }
  </div>
</article>
