---
interface Props {
  title: string;
  intro?: string;
  allowed: string[];
  avoid: string[];
}

const { title, intro, allowed, avoid } = Astro.props as Props;
---

<section class="panel disclosure-card reveal-enter">
  <span class="mini-label">PUBLIC-SAFE GUIDANCE</span>
  <h3>{title}</h3>
  {intro ? <p>{intro}</p> : null}

  <div class="disclosure-grid">
    <div>
      <span class="footer-label">Safe to show</span>
      <ul class="meta-list">
        {allowed.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <div>
      <span class="footer-label">Keep out</span>
      <ul class="meta-list">
        {avoid.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>
</section>
