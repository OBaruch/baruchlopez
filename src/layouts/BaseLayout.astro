---
import SmoothExperienceRuntime from "@/components/react/SmoothExperienceRuntime";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Baruch Lopez | Portal",
  description = "Baruch Lopez's static portal across Cyrus Global Capital, Alpha Signature, Corporate Profile, Personal Project Lab, talks, and contact.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#030304" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://baruchlopez.com/" />
    <link rel="canonical" href="https://baruchlopez.com/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      document.documentElement.classList.add("js-ready");
      window.setTimeout(() => {
        if (!document.documentElement.classList.contains("fx-ready")) {
          document.documentElement.classList.add("fx-ready");
        }
      }, 1800);
    </script>
  </head>
  <body>
    <SmoothExperienceRuntime client:load />
    <slot />
  </body>
</html>
