---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { personSchema, siteMeta } from "@/data/site";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  canonicalPath?: string;
  structuredData?: Record<string, unknown>;
  lang?: string;
  redirectTo?: string;
  noindex?: boolean;
}

const {
  title = siteMeta.defaultTitle,
  description = siteMeta.defaultDescription,
  currentPath = "/",
  canonicalPath = currentPath,
  structuredData = personSchema,
  lang = "en",
  redirectTo,
  noindex = false,
} = Astro.props as Props;

const siteUrl = Astro.site?.toString() ?? siteMeta.site;
const canonical = new URL(redirectTo ?? canonicalPath, siteUrl).toString();
const ogImage = new URL(siteMeta.ogImage, siteUrl).toString();
const ogImageAlt = "Portrait of Baruch López.";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {redirectTo ? <meta http-equiv="refresh" content={`0; url=${redirectTo}`} /> : null}
    {noindex ? <meta name="robots" content="noindex,follow" /> : null}
    <meta name="author" content={siteMeta.name} />
    <meta name="theme-color" content="#030304" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:site_name" content={siteMeta.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          document.documentElement.classList.add("motion-ready");
        }
      })();
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <div class="site-progress" aria-hidden="true"><span data-site-progress></span></div>
    <div class="site-shell">
      <SiteHeader currentPath={currentPath} />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </div>

    <script is:inline>
      (() => {
        const mobileQuery = window.matchMedia("(max-width: 840px)");
        const body = document.body;
        const progressBar = document.querySelector("[data-site-progress]");
        const revealItems = Array.from(document.querySelectorAll(".reveal-enter"));
        const scrollPassthroughAreas = Array.from(document.querySelectorAll(".site-nav"));
        const canUseMotion = document.documentElement.classList.contains("motion-ready");
        let lastY = window.scrollY;
        let ticking = false;

        const applyScrollProgress = () => {
          if (!progressBar) {
            return;
          }

          const maxScroll = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
          const progress = Math.min(1, Math.max(0, window.scrollY / maxScroll));
          progressBar.style.transform = `scaleX(${progress})`;
        };

        const applyHeaderState = () => {
          ticking = false;
          applyScrollProgress();

          if (!mobileQuery.matches) {
            body.classList.remove("mobile-header-condensed");
            lastY = window.scrollY;
            return;
          }

          const currentY = window.scrollY;
          const delta = currentY - lastY;

          if (currentY <= 36) {
            body.classList.remove("mobile-header-condensed");
          } else if (delta > 7 && currentY > 120) {
            body.classList.add("mobile-header-condensed");
          } else if (delta < -7) {
            body.classList.remove("mobile-header-condensed");
          }

          lastY = currentY;
        };

        const requestHeaderUpdate = () => {
          if (ticking) {
            return;
          }

          ticking = true;
          window.requestAnimationFrame(applyHeaderState);
        };

        mobileQuery.addEventListener("change", applyHeaderState);
        window.addEventListener("scroll", requestHeaderUpdate, { passive: true });
        window.addEventListener("resize", applyHeaderState);
        scrollPassthroughAreas.forEach((area) => {
          area.addEventListener(
            "wheel",
            (event) => {
              if (Math.abs(event.deltaY) <= Math.abs(event.deltaX) || event.deltaY === 0) {
                return;
              }

              const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
              if (maxScroll <= 0) {
                return;
              }

              event.preventDefault();
              window.scrollBy({ top: event.deltaY, left: 0, behavior: "auto" });
            },
            { passive: false }
          );
        });
        applyHeaderState();

        if (!canUseMotion || !("IntersectionObserver" in window)) {
          revealItems.forEach((item) => item.classList.add("is-visible"));
          return;
        }

        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) {
                return;
              }

              entry.target.classList.add("is-visible");
              revealObserver.unobserve(entry.target);
            });
          },
          { threshold: 0.14, rootMargin: "0px 0px -8% 0px" }
        );

        revealItems.forEach((item, index) => {
          item.style.setProperty("--reveal-delay", `${Math.min(index % 4, 3) * 45}ms`);
          revealObserver.observe(item);
        });
      })();
    </script>
  </body>
</html>
