---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { personSchema, siteMeta } from "@/data/site";
import { i18nRuntime } from "@/i18n/runtime";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  canonicalPath?: string;
  structuredData?: Record<string, unknown>;
  lang?: string;
  redirectTo?: string;
  noindex?: boolean;
}

const {
  title = siteMeta.defaultTitle,
  description = siteMeta.defaultDescription,
  currentPath = "/",
  canonicalPath = currentPath,
  structuredData = personSchema,
  lang = "en",
  redirectTo,
  noindex = false,
} = Astro.props as Props;

const siteUrl = Astro.site?.toString() ?? siteMeta.site;
const canonical = new URL(redirectTo ?? canonicalPath, siteUrl).toString();
const ogImage = new URL(siteMeta.ogImage, siteUrl).toString();
const ogImageAlt = "Portrait of Baruch López.";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {redirectTo ? <meta http-equiv="refresh" content={`0; url=${redirectTo}`} /> : null}
    {noindex ? <meta name="robots" content="noindex,follow" /> : null}
    <meta name="author" content={siteMeta.name} />
    <meta name="theme-color" content="#030304" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:site_name" content={siteMeta.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="canonical" href={canonical} />
    <meta name="i18n-strategy" content="client-detected-en-es" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          document.documentElement.classList.add("motion-ready");
        }
      })();
    </script>
    <script is:inline define:vars={{ i18nRuntime }}>
      (() => {
        const config = i18nRuntime;
        const html = document.documentElement;
        const readCookie = (name) => {
          const match = document.cookie.match(new RegExp(`(?:^|; )${name}=([^;]*)`));
          return match ? decodeURIComponent(match[1]) : "";
        };
        const normalizeLocale = (value) => {
          const next = String(value || "").toLowerCase().slice(0, 2);
          return config.supportedLocales.includes(next) ? next : "";
        };
        const localeFromNavigator = () => {
          const languages = navigator.languages?.length ? navigator.languages : [navigator.language];
          return languages.some((language) => String(language || "").toLowerCase().startsWith("es")) ? "es" : "";
        };
        const detectInitialLocale = () => {
          const stored = normalizeLocale(window.localStorage?.getItem(config.storageKey));
          if (stored) return stored;

          const manualCookie = normalizeLocale(readCookie(config.manualCookie));
          if (manualCookie) return manualCookie;

          const geoCookie = normalizeLocale(readCookie(config.geoCookie));
          if (geoCookie) return geoCookie;

          return localeFromNavigator() || config.defaultLocale;
        };

        window.__BARUCH_I18N__ = config;
        window.__BARUCH_LOCALE__ = detectInitialLocale();
        html.lang = window.__BARUCH_LOCALE__;
        html.dataset.locale = window.__BARUCH_LOCALE__;
      })();
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <div class="site-progress" aria-hidden="true"><span data-site-progress></span></div>
    <div class="site-shell">
      <SiteHeader currentPath={currentPath} />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </div>

    <script is:inline>
      (() => {
        const config = window.__BARUCH_I18N__;
        if (!config) return;

        const originalText = new WeakMap();
        const translatedAttributes = ["aria-label", "title", "alt", "placeholder", "content"];
        const attributeOriginalName = (attribute) => `data-i18n-original-${attribute.replace(/[^a-z0-9]+/gi, "-")}`;
        const ignoredSelector = "script, style, noscript, code, pre, [data-i18n-ignore]";

        const readCookie = (name) => {
          const match = document.cookie.match(new RegExp(`(?:^|; )${name}=([^;]*)`));
          return match ? decodeURIComponent(match[1]) : "";
        };

        const writeCookie = (name, value, maxAge = 31536000) => {
          document.cookie = `${name}=${encodeURIComponent(value)}; Path=/; Max-Age=${maxAge}; SameSite=Lax`;
        };

        const normalizeLocale = (value) => {
          const next = String(value || "").toLowerCase().slice(0, 2);
          return config.supportedLocales.includes(next) ? next : "";
        };

        const getDictionary = (locale) => config.dictionaries[locale]?.phrases || {};

        const translate = (source, locale) => {
          const text = String(source || "");
          const trimmed = text.replace(/\s+/g, " ").trim();
          if (!trimmed) return text;

          const dictionary = getDictionary(locale);
          let translated = dictionary[trimmed] || trimmed;

          if (translated === trimmed) {
            const entries = Object.entries(dictionary)
              .filter(([from]) => from.length > 6 && trimmed.includes(from))
              .sort((left, right) => right[0].length - left[0].length);
            translated = entries.reduce((value, [from, to]) => value.split(from).join(to), trimmed);
          }

          const leading = text.match(/^\s*/)?.[0] || "";
          const trailing = text.match(/\s*$/)?.[0] || "";
          return `${leading}${translated}${trailing}`;
        };

        const updateTextNodes = (locale) => {
          const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
            acceptNode(node) {
              const parent = node.parentElement;
              if (!parent || parent.closest(ignoredSelector)) return NodeFilter.FILTER_REJECT;
              if (!node.nodeValue || !node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
              return NodeFilter.FILTER_ACCEPT;
            },
          });

          const nodes = [];
          while (walker.nextNode()) nodes.push(walker.currentNode);

          nodes.forEach((node) => {
            if (!originalText.has(node)) originalText.set(node, node.nodeValue || "");
            node.nodeValue = translate(originalText.get(node), locale);
          });
        };

        const updateAttributes = (locale) => {
          const elements = Array.from(document.querySelectorAll("[aria-label], [title], [alt], [placeholder], meta[name='description'], meta[property='og:description'], meta[name='twitter:description'], meta[property='og:title'], meta[name='twitter:title']"));
          elements.forEach((element) => {
            if (element.closest?.(ignoredSelector)) return;
            translatedAttributes.forEach((attribute) => {
              if (!element.hasAttribute(attribute)) return;
              const originalName = attributeOriginalName(attribute);
              if (!element.hasAttribute(originalName)) {
                element.setAttribute(originalName, element.getAttribute(attribute) || "");
              }
              element.setAttribute(attribute, translate(element.getAttribute(originalName) || "", locale));
            });
          });

          if (!document.documentElement.hasAttribute("data-i18n-original-title")) {
            document.documentElement.setAttribute("data-i18n-original-title", document.title);
          }
          document.title = translate(document.documentElement.getAttribute("data-i18n-original-title") || document.title, locale);
        };

        const syncManifestoLanguage = (locale) => {
          const target = document.getElementById(`manifesto-language-${locale}`);
          if (target && "checked" in target && !target.checked) {
            target.checked = true;
            target.dispatchEvent(new Event("change", { bubbles: true }));
          }
        };

        const updateLanguageButtons = (locale) => {
          document.querySelectorAll("[data-language-option]").forEach((button) => {
            const active = button.getAttribute("data-language-option") === locale;
            button.setAttribute("aria-pressed", String(active));
          });
        };

        const applyLocale = (locale, options = {}) => {
          const nextLocale = normalizeLocale(locale) || config.defaultLocale;
          window.__BARUCH_LOCALE__ = nextLocale;
          document.documentElement.lang = nextLocale;
          document.documentElement.dataset.locale = nextLocale;
          updateTextNodes(nextLocale);
          updateAttributes(nextLocale);
          updateLanguageButtons(nextLocale);
          syncManifestoLanguage(nextLocale);

          if (options.persist) {
            window.localStorage?.setItem(config.storageKey, nextLocale);
            writeCookie(config.manualCookie, nextLocale);
          }

          window.dispatchEvent(new CustomEvent("baruch:languagechange", { detail: { locale: nextLocale } }));
        };

        window.BaruchI18n = { applyLocale };

        document.querySelectorAll("[data-language-option]").forEach((button) => {
          button.addEventListener("click", () => {
            applyLocale(button.getAttribute("data-language-option"), { persist: true });
          });
        });

        const initialLocale =
          normalizeLocale(window.__BARUCH_LOCALE__) ||
          normalizeLocale(window.localStorage?.getItem(config.storageKey)) ||
          normalizeLocale(readCookie(config.manualCookie)) ||
          normalizeLocale(readCookie(config.geoCookie)) ||
          config.defaultLocale;

        applyLocale(initialLocale);
      })();
    </script>

    <script is:inline>
      (() => {
        const mobileQuery = window.matchMedia("(max-width: 840px)");
        const body = document.body;
        const progressBar = document.querySelector("[data-site-progress]");
        const revealItems = Array.from(document.querySelectorAll(".reveal-enter"));
        const scrollPassthroughAreas = Array.from(document.querySelectorAll(".site-nav"));
        const canUseMotion = document.documentElement.classList.contains("motion-ready");
        let lastY = window.scrollY;
        let ticking = false;

        const applyScrollProgress = () => {
          if (!progressBar) {
            return;
          }

          const maxScroll = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
          const progress = Math.min(1, Math.max(0, window.scrollY / maxScroll));
          progressBar.style.transform = `scaleX(${progress})`;
        };

        const applyHeaderState = () => {
          ticking = false;
          applyScrollProgress();

          if (!mobileQuery.matches) {
            body.classList.remove("mobile-header-condensed");
            lastY = window.scrollY;
            return;
          }

          const currentY = window.scrollY;
          const delta = currentY - lastY;

          if (currentY <= 36) {
            body.classList.remove("mobile-header-condensed");
          } else if (delta > 7 && currentY > 120) {
            body.classList.add("mobile-header-condensed");
          } else if (delta < -7) {
            body.classList.remove("mobile-header-condensed");
          }

          lastY = currentY;
        };

        const requestHeaderUpdate = () => {
          if (ticking) {
            return;
          }

          ticking = true;
          window.requestAnimationFrame(applyHeaderState);
        };

        mobileQuery.addEventListener("change", applyHeaderState);
        window.addEventListener("scroll", requestHeaderUpdate, { passive: true });
        window.addEventListener("resize", applyHeaderState);
        scrollPassthroughAreas.forEach((area) => {
          area.addEventListener(
            "wheel",
            (event) => {
              if (Math.abs(event.deltaY) <= Math.abs(event.deltaX) || event.deltaY === 0) {
                return;
              }

              const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
              if (maxScroll <= 0) {
                return;
              }

              event.preventDefault();
              window.scrollBy({ top: event.deltaY, left: 0, behavior: "auto" });
            },
            { passive: false }
          );
        });
        applyHeaderState();

        if (!canUseMotion || !("IntersectionObserver" in window)) {
          revealItems.forEach((item) => item.classList.add("is-visible"));
          return;
        }

        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) {
                return;
              }

              entry.target.classList.add("is-visible");
              revealObserver.unobserve(entry.target);
            });
          },
          { threshold: 0.14, rootMargin: "0px 0px -8% 0px" }
        );

        revealItems.forEach((item, index) => {
          item.style.setProperty("--reveal-delay", `${Math.min(index % 4, 3) * 45}ms`);
          revealObserver.observe(item);
        });
      })();
    </script>
  </body>
</html>
