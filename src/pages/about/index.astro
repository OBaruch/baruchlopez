---
import CTASection from "@/components/CTASection.astro";
import ContextNav from "@/components/ContextNav.astro";
import PageHero from "@/components/PageHero.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import Timeline from "@/components/Timeline.astro";
import {
  aboutBio,
  condensedTimeline,
  educationHighlights,
  futureDirections,
  philosophyCards,
} from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";

const aboutGuide = [
  { label: "Story", href: "#about-story", note: "Read the core narrative" },
  { label: "Timeline", href: "#about-timeline", note: "See the progression" },
  { label: "Full timeline", href: "/timeline/", note: "Open the complete chronology" },
  { label: "Education", href: "#about-education", note: "Review the foundation" },
  { label: "Philosophy", href: "#about-philosophy", note: "How the work is framed" },
  { label: "Direction", href: "#about-direction", note: "Where it is going" },
];
---

<BaseLayout
  title="About Baruch López | Robotics, AI and Structured Growth"
  description="Read the professional story of Baruch López across robotics, AI, data systems, corporate execution, business education and structured growth."
  currentPath={Astro.url.pathname}
  canonicalPath="/about/"
>
  <PageHero
    eyebrow={aboutBio.eyebrow}
    title={aboutBio.title}
    intro={aboutBio.intro}
    body={aboutBio.body.join(" ")}
    actions={[
      { label: "View Experience", href: "/experience/", variant: "primary" },
      { label: "Explore Projects", href: "/projects/", variant: "secondary" },
    ]}
  />

  <section class="section-shell section-shell-tight">
    <div class="container">
      <ContextNav
        title="Read the story through five useful lenses."
        copy="About focuses on continuity: the technical base, the current work, the education layer, the working philosophy and the direction ahead."
        items={aboutGuide}
      />
    </div>
  </section>

  <section class="section-shell" id="about-story">
    <div class="container prose-section">
      <SectionHeader
        eyebrow="PUBLIC STORY"
        title="Engineering first, then systems, execution and institutional context."
        copy="The throughline is not a sudden pivot. It is a technical foundation expanding into systems, business judgment and longer-term operating structure."
      />

      <div class="card-grid card-grid-3">
        <article class="panel reveal-enter">
          <h3>Technical origin</h3>
          <p>Robotics and engineering created the first layer: systems, experimentation, technical discipline and applied problem solving.</p>
        </article>
        <article class="panel reveal-enter">
          <h3>Current layer</h3>
          <p>The profile now sits across AI, data systems, automation, documentation and business-facing execution.</p>
        </article>
        <article class="panel reveal-enter">
          <h3>Why it matters</h3>
          <p>That range explains why the site connects corporate work, consulting, finance context and technical exploration.</p>
        </article>
      </div>

      <div class="section-spacer-sm"></div>

      <div class="narrative-grid">
        {aboutBio.body.map((paragraph) => <p class="lead-paragraph reveal-enter">{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="section-shell" id="about-timeline">
    <div class="container">
      <SectionHeader
        eyebrow="TIMELINE"
        title="The shortest accurate version of the path."
        copy="The short timeline gives a quick sense of progression before opening Experience, Projects or the full chronology."
      />
      <Timeline items={condensedTimeline} />
      <div class="button-row">
        <a class="button-link button-link-secondary" href="/timeline/">Open full timeline</a>
      </div>
    </div>
  </section>

  <section class="section-shell" id="about-education">
    <div class="container">
      <SectionHeader
        eyebrow="EDUCATION"
        title="Technical foundation with current business expansion."
        copy="Education explains both the original engineering layer and the current expansion toward management, leadership, finance and structured growth."
      />

      <div class="card-grid">
        {
          educationHighlights.map((item) => (
            <article class="panel reveal-enter">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell" id="about-philosophy">
    <div class="container">
      <SectionHeader
        eyebrow="WORKING PHILOSOPHY"
        title="Clear, disciplined and useful."
        copy="These principles explain the kind of work Baruch gravitates toward: systems that clarify, reduce noise and hold up under real use."
      />

      <div class="card-grid card-grid-3">
        {
          philosophyCards.map((item) => (
            <article class="panel reveal-enter">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell section-shell-last" id="about-direction">
    <div class="container">
      <SectionHeader
        eyebrow="FUTURE DIRECTION"
        title="What this platform is growing toward."
        copy="The profile is still compounding. The public site keeps that direction visible without making claims ahead of the evidence."
      />

      <div class="panel reveal-enter">
        <ul class="meta-list meta-list-spacious">
          {futureDirections.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="section-spacer-sm"></div>

      <CTASection
        eyebrow="NEXT STEP"
        title="Go from story to proof."
        body="Experience gives the formal professional layer, Projects gives technical depth, and the Manifesto gives the values framework behind the work."
        actions={[
          { label: "View Experience", href: "/experience/", variant: "primary" },
          { label: "Explore Projects", href: "/projects/", variant: "secondary" },
          { label: "Read the Manifesto", href: "/manifesto/", variant: "ghost" },
        ]}
      />
    </div>
  </section>
</BaseLayout>
