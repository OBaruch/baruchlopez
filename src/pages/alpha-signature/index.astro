---
import LinkButton from "@/components/LinkButton.astro";
import { alphaPage } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Alpha Signature | Official Site"
  description="Redirecting to the official Alpha Signature website."
  currentPath={Astro.url.pathname}
  canonicalPath={alphaPage.officialHref}
  redirectTo={alphaPage.officialHref}
  noindex={true}
>
  <section class="hero-shell hero-shell-text">
    <div class="container hero-grid">
      <div class="hero-copy reveal-enter">
        <span class="eyebrow">ALPHA SIGNATURE</span>
        <h1>Redirecting to Alpha Signature.</h1>
        <p class="hero-intro">
          Alpha Signature now lives on its official website. This route is kept only as a
          compatibility path.
        </p>

        <div class="button-row">
          <LinkButton label="Continue to Alpha Signature" href={alphaPage.officialHref} variant="primary" external={true} />
          <LinkButton label="Back to Baruch López" href="/" variant="ghost" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
