---
import CTASection from "@/components/CTASection.astro";
import PathwayCard from "@/components/PathwayCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { contactPathways } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Baruch Lopez"
  description="Professional pathways and external links for the public profile of Baruch Lopez."
  currentPath={Astro.url.pathname}
  canonicalPath="/contact/"
>
  <section class="hero-shell hero-shell-text">
    <div class="container hero-grid">
      <div class="hero-copy reveal-enter">
        <span class="eyebrow">CONTACT</span>
        <h1>Choose the right channel.</h1>
        <p class="hero-intro">
          For professional context, consulting, selected projects or external references.
        </p>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="PATHWAYS"
        title="Different intents, different next steps."
        copy="This page works best as routing, not as a catch-all contact dump. Choose the channel that matches the conversation you actually want to have."
      />

      <div class="card-grid card-grid-2">
        {contactPathways.map((item) => <PathwayCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="CONTACT APPROACH"
        title="Public channels stay intentional and low-friction."
        copy="The architecture avoids fake forms, unverified contact data and unnecessary friction. It routes visitors through channels that are already public, confirmed and appropriate."
      />

      <article class="panel reveal-enter">
        <p>
          For recruiting or formal background checks, LinkedIn is the fastest route. For technical
          credibility and code-adjacent context, GitHub is stronger. For consulting or institutional
          conversations, the site first frames the relevant layer so outreach starts with clearer
          expectations.
        </p>
      </article>
    </div>
  </section>

  <section class="section-shell section-shell-last">
    <div class="container">
      <CTASection
        eyebrow="NEXT STEP"
        title="Use the site as a gateway, not a data collection form."
        body="The goal is clarity and trust: the user understands where to go, what that path is for and why the site avoids collecting unnecessary information."
        actions={[
          { label: "Open LinkedIn", href: "https://www.linkedin.com/in/baruchlopez/", variant: "primary", external: true },
          { label: "Open GitHub", href: "https://github.com/OBaruch", variant: "secondary", external: true },
        ]}
      />
    </div>
  </section>
</BaseLayout>
