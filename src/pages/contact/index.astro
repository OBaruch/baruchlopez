---
import CTASection from "@/components/CTASection.astro";
import PathwayCard from "@/components/PathwayCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { contactPathways } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Baruch López"
  description="Professional pathways and external links for the public profile of Baruch López."
  currentPath={Astro.url.pathname}
  canonicalPath="/contact/"
>
  <section class="hero-shell hero-shell-text">
    <div class="container hero-grid">
      <div class="hero-copy reveal-enter">
        <span class="eyebrow">CONTACT</span>
        <h1>Choose the right channel.</h1>
        <p class="hero-intro">
          For professional context, consulting, selected projects or external references.
        </p>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="PATHWAYS"
        title="Different intents, clear next steps."
        copy="Choose the route that best matches the conversation: recruiting, technical reference, consulting context or institutional context."
      />

      <div class="card-grid card-grid-2">
        {contactPathways.map((item) => <PathwayCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="CONTACT APPROACH"
        title="Public channels stay intentional and low-friction."
        copy="The site routes visitors through public, confirmed channels instead of collecting unnecessary information."
      />

      <article class="panel reveal-enter">
        <p>
          For recruiting or formal background checks, LinkedIn is the fastest route. For technical
          credibility and code-adjacent context, GitHub is stronger. For consulting or institutional
          conversations, the site first frames the relevant layer so outreach starts with clearer
          expectations.
        </p>
      </article>
    </div>
  </section>

  <section class="section-shell section-shell-last">
    <div class="container">
      <CTASection
        eyebrow="NEXT STEP"
        title="Start from a public, verified channel."
        body="LinkedIn is best for formal background and professional outreach. GitHub is best for public repositories and technical reference."
        actions={[
          { label: "Open LinkedIn", href: "https://www.linkedin.com/in/baruchlopez/", variant: "primary", external: true },
          { label: "Open GitHub", href: "https://github.com/OBaruch", variant: "secondary", external: true },
        ]}
      />
    </div>
  </section>
</BaseLayout>
