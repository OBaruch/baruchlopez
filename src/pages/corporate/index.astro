---
import CTASection from "@/components/CTASection.astro";
import PageHero from "@/components/PageHero.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { corporateHero, corporateThemes } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Corporate Profile | Baruch López"
  description="A high-level corporate overview of Baruch López across enterprise AI, analytics, ETL, reporting and technical enablement."
  currentPath={Astro.url.pathname}
  canonicalPath="/corporate/"
>
  <PageHero
    eyebrow={corporateHero.eyebrow}
    title={corporateHero.title}
    intro={corporateHero.intro}
    actions={[
      {
        label: "Open LinkedIn",
        href: "https://www.linkedin.com/in/baruchlopez/",
        variant: "primary",
        external: true,
      },
      { label: "Contact", href: "/contact/", variant: "secondary" },
    ]}
  />

  <section class="section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="CORPORATE OVERVIEW"
        title="Enterprise capability, clearly framed."
        copy="This layer reflects enterprise-facing work across AI, data, analytics, automation and enablement at a level appropriate for a public professional profile."
      />

      <div class="card-grid card-grid-2">
        {
          corporateThemes.map((item) => (
            <article class="panel reveal-enter">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell section-shell-last">
    <div class="container">
      <CTASection
        eyebrow="NEXT STEP"
        title="Move from enterprise context to broader profile."
        body="Experience gives the broader career read, and Projects adds technical exploration and archive depth."
        actions={[
          { label: "View Experience", href: "/experience/", variant: "primary" },
          { label: "Explore Projects", href: "/projects/", variant: "secondary" },
        ]}
      />
    </div>
  </section>
</BaseLayout>
