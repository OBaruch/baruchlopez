---
import CertificationCard from "@/components/CertificationCard.astro";
import ContextNav from "@/components/ContextNav.astro";
import CTASection from "@/components/CTASection.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { certifications } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";

const featured = certifications.filter((item) => item.featured);
const archive = certifications.filter((item) => !item.featured);
const archiveByCategory = Object.entries(
  archive.reduce<Record<string, typeof archive>>((groups, item) => {
    groups[item.category] ??= [];
    groups[item.category].push(item);
    return groups;
  }, {}),
).sort((a, b) => a[0].localeCompare(b[0]));

const credentialGuide = [
  { label: "Why this page exists", href: "#credentials-why", note: "Read the framing" },
  { label: "Featured", href: "#credentials-featured", note: "Start with the shortest useful set" },
  { label: "Archive", href: "#credentials-archive", note: "Browse grouped categories" },
];

const uniqueCategories = new Set(certifications.map((item) => item.category)).size;
---

<BaseLayout
  title="Credentials | Baruch Lopez"
  description="A structured archive of public certifications, courses and technical development associated with Baruch Lopez."
  currentPath={Astro.url.pathname}
  canonicalPath="/credentials/"
>
  <section class="hero-shell hero-shell-text">
    <div class="container hero-grid">
      <div class="hero-copy reveal-enter">
        <span class="eyebrow">CREDENTIALS</span>
        <h1>Public certifications and training archive.</h1>
        <p class="hero-intro">
          This page keeps visible credentials together without turning the homepage or Experience
          pages into long walls of certificates.
        </p>
        <p class="hero-body">
          Internal corporate-only training is intentionally excluded. What appears here is limited to
          public or public-safe credentials.
        </p>
      </div>
    </div>
  </section>

  <section class="section-shell section-shell-tight" id="credentials-why">
    <div class="container">
      <ContextNav
        title="Use this page as support, not as the main story."
        copy="Credentials help validate range and continuity, but they should stay secondary to experience, projects and the broader narrative."
        items={credentialGuide}
      />
    </div>
  </section>

  <section class="section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="AT A GLANCE"
        title="A structured archive, not a certificate wall."
        copy="This page keeps breadth visible while preserving readability. The archive is grouped by category so users can scan quickly before opening individual items."
      />

      <div class="card-grid card-grid-3">
        <article class="panel reveal-enter">
          <h3>{featured.length}</h3>
          <p>Featured credentials selected for narrative value and public relevance.</p>
        </article>
        <article class="panel reveal-enter">
          <h3>{certifications.length}</h3>
          <p>Total public or public-safe entries included in the archive.</p>
        </article>
        <article class="panel reveal-enter">
          <h3>{uniqueCategories}</h3>
          <p>Categories spanning AI, leadership, finance, cloud, language and technical development.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-shell" id="credentials-featured">
    <div class="container">
      <SectionHeader
        eyebrow="FEATURED"
        title="The shortest useful read."
        copy="Start here if you only need the highest-signal public credentials without opening the broader archive."
      />
      <div class="card-grid card-grid-certifications">
        {featured.map((item) => <CertificationCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="section-shell section-shell-last" id="credentials-archive">
    <div class="container">
      <SectionHeader
        eyebrow="ARCHIVE"
        title="Grouped archive for faster scanning."
        copy="The extended archive is grouped by category to reduce noise and help the reader jump straight to the kind of development that matters most."
      />

      <div class="category-stack">
        {
          archiveByCategory.map(([category, items]) => (
            <section class="category-stack-section reveal-enter" aria-labelledby={`credentials-${category.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}>
              <div class="category-stack-header">
                <span class="mini-label">Category</span>
                <h3 id={`credentials-${category.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}>{category}</h3>
              </div>
              <div class="card-grid card-grid-certifications">
                {items.map((item) => <CertificationCard item={item} />)}
              </div>
            </section>
          ))
        }
      </div>

      <div class="section-spacer-sm"></div>

      <CTASection
        eyebrow="NEXT STEP"
        title="Move back to experience or projects."
        body="Credentials support trust, but the stronger reading still comes from trajectory, systems thinking and selected public work."
        actions={[
          { label: "View Experience", href: "/experience/", variant: "primary" },
          { label: "Explore Projects", href: "/projects/", variant: "secondary" },
        ]}
      />
    </div>
  </section>
</BaseLayout>
