---
import LinkButton from "@/components/LinkButton.astro";
import { cyrusPage } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Cyrus Global Capital | Official Site"
  description="Redirecting to the official Cyrus Global Capital website."
  currentPath={Astro.url.pathname}
  canonicalPath={cyrusPage.officialHref}
  redirectTo={cyrusPage.officialHref}
  noindex={true}
>
  <section class="hero-shell hero-shell-text">
    <div class="container hero-grid">
      <div class="hero-copy reveal-enter">
        <span class="eyebrow">CYRUS GLOBAL CAPITAL</span>
        <h1>Redirecting to Cyrus Global Capital.</h1>
        <p class="hero-intro">
          Cyrus Global Capital now lives on its official website. This route is kept only as a
          compatibility path.
        </p>

        <div class="button-row">
          <LinkButton label="Continue to Cyrus Global Capital" href={cyrusPage.officialHref} variant="primary" external={true} />
          <LinkButton label="Back to Baruch López" href="/" variant="ghost" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
