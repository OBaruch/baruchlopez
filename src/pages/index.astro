---
import CTASection from "@/components/CTASection.astro";
import ContextNav from "@/components/ContextNav.astro";
import type { IconName } from "@/components/IconGlyph.astro";
import PageHero from "@/components/PageHero.astro";
import PathwayCard from "@/components/PathwayCard.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import RecognitionCard from "@/components/RecognitionCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import SkillCluster from "@/components/SkillCluster.astro";
import Timeline from "@/components/Timeline.astro";
import VerticalCard from "@/components/VerticalCard.astro";
import { recognitionItems } from "@/data/recognitions";
import {
  condensedTimeline,
  featuredProjects,
  homeHero,
  homePathways,
  siteMeta,
  skillClusters,
  trustSignals,
  verticals,
} from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";

const homeGuide: Array<{ label: string; href: string; note: string; icon: IconName }> = [
  { label: "Start here", href: "#home-pathways", note: "Choose a path", icon: "compass" },
  { label: "Mural", href: "/recognitions/", note: "Open recognitions", icon: "work" },
  { label: "Core areas", href: "#home-domains", note: "See the ecosystem", icon: "layers" },
  { label: "Snapshot", href: "#home-snapshot", note: "Read the short profile", icon: "profile" },
  { label: "Trajectory", href: "#home-trajectory", note: "Follow the progression", icon: "timeline" },
  { label: "Selected work", href: "#home-projects", note: "Open projects", icon: "work" },
  { label: "Capabilities", href: "#home-capabilities", note: "Review the range", icon: "systems" },
];

const recognitionPreview = recognitionItems.slice(0, 3);
---

<BaseLayout
  title={siteMeta.defaultTitle}
  description={siteMeta.defaultDescription}
  currentPath={Astro.url.pathname}
  canonicalPath="/"
>
  <PageHero {...homeHero} />

  <section class="section-shell section-shell-tight" id="home-pathways">
    <div class="container">
      <ContextNav
        title="Start with the path that fits your reason for visiting."
        copy="Recruiters, collaborators, clients and technical peers usually need different levels of detail. The site is structured so each group can move quickly."
        items={homeGuide}
      />
    </div>
  </section>

  <section class="section-shell" id="home-recognitions">
    <div class="container">
      <SectionHeader
        eyebrow="MURAL DE RECONOCIMIENTOS"
        title="A visual archive of verified milestones."
        copy="A curated view of public certificates, recognitions and awards, organized chronologically with document previews and context."
      />

      <div class="recognition-feature-grid">
        {recognitionPreview.map((item) => <RecognitionCard item={item} compact={true} />)}
      </div>

      <div class="button-row">
        <a class="button-link button-link-primary" href="/recognitions/"><span>Open Mural</span></a>
        <a class="button-link button-link-secondary" href="/credentials/"><span>View Credentials</span></a>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="START HERE"
        title="A personal hub with clear entry points."
        copy="Baruch's work spans AI, data, consulting, finance context and public projects. These pathways keep the first visit focused."
      />

      <div class="card-grid card-grid-2">
        {homePathways.map((item) => <PathwayCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="section-shell" id="home-domains">
    <div class="container">
      <SectionHeader
        eyebrow="CORE AREAS"
        title="One identity, several professional layers."
        copy="The site separates corporate experience, Alpha Signature, Cyrus Global Capital context and the Project Lab so each layer stays clear and credible."
      />

      <div class="card-grid card-grid-4">
        {verticals.map((item) => <VerticalCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="section-shell" id="home-snapshot">
    <div class="container">
      <SectionHeader
        eyebrow="EXECUTIVE SNAPSHOT"
        title="The short version before the deeper pages."
        copy="A quick read on the current role, technical foundation, business expansion and broader builder ecosystem."
      />

      <div class="card-grid">
        {
          trustSignals.map((item) => (
            <article class="panel reveal-enter">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell" id="home-trajectory">
    <div class="container">
      <SectionHeader
        eyebrow="TRAJECTORY"
        title="A path that keeps expanding in range."
        copy="The progression moves from robotics and engineering foundations into enterprise AI, business education, consulting and carefully framed finance context."
      />
      <Timeline items={condensedTimeline} />
    </div>
  </section>

  <section class="section-shell" id="home-projects">
    <div class="container">
      <SectionHeader
        eyebrow="SELECTED WORK"
        title="A curated set of projects and systems."
        copy="The Project Lab highlights technical evolution, systems thinking and selected public work without presenting every prototype as a finished product."
      />

      <div class="card-grid card-grid-projects">
        {featuredProjects.slice(0, 4).map((item) => <ProjectCard item={item} compact={true} />)}
      </div>
    </div>
  </section>

  <section class="section-shell" id="home-capabilities">
    <div class="container">
      <SectionHeader
        eyebrow="CAPABILITIES"
        title="Engineering discipline with business-facing clarity."
        copy="The strongest pattern is the ability to connect technical depth, documentation, operating structure and decision-support clarity."
      />

      <div class="card-grid card-grid-2">
        {skillClusters.map((cluster) => <SkillCluster cluster={cluster} />)}
      </div>
    </div>
  </section>

  <section class="section-shell section-shell-last">
    <div class="container">
      <CTASection
        eyebrow="NEXT PATHWAY"
        title="Continue with the layer that matters most."
        body="Experience gives the formal profile, Projects gives technical depth, Timeline adds chronology, and Contact keeps outreach simple."
        actions={[
          { label: "View Experience", href: "/experience/", variant: "primary" },
          { label: "Contact", href: "/contact/", variant: "secondary" },
          { label: "Open Timeline", href: "/timeline/", variant: "secondary" },
          { label: "Read the Manifesto", href: "/manifesto/", variant: "ghost" },
        ]}
      />
    </div>
  </section>
</BaseLayout>
