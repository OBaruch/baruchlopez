---
import CTASection from "@/components/CTASection.astro";
import PageHero from "@/components/PageHero.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import SkillCluster from "@/components/SkillCluster.astro";
import Timeline from "@/components/Timeline.astro";
import VerticalCard from "@/components/VerticalCard.astro";
import {
  condensedTimeline,
  featuredProjects,
  homeHero,
  siteMeta,
  skillClusters,
  trustSignals,
  verticals,
} from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title={siteMeta.defaultTitle}
  description={siteMeta.defaultDescription}
  currentPath={Astro.url.pathname}
  canonicalPath="/"
>
  <PageHero {...homeHero} />

  <section class="section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="CORE DOMAINS"
        title="Four connected verticals, one central identity."
        copy="The personal site acts as the hub. Each vertical explains a different layer of the public profile without collapsing them into one generic story."
      />

      <div class="card-grid card-grid-4">
        {verticals.map((item) => <VerticalCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="EXECUTIVE SNAPSHOT"
        title="A concise read before the deeper pages."
        copy="The goal is clarity first: current work, technical foundation, institutional range and academic growth."
      />

      <div class="card-grid">
        {
          trustSignals.map((item) => (
            <article class="panel reveal-enter">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="TRAJECTORY"
        title="A professional path that keeps expanding in range."
        copy="From robotics and engineering foundations to enterprise AI, institutional context and structured growth."
      />
      <Timeline items={condensedTimeline} />
    </div>
  </section>

  <section class="section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="SELECTED WORK"
        title="A curated set of projects and systems."
        copy="The Project Lab is not a raw archive. It is a curated reading of technical evolution, product thinking and public-safe experimentation."
      />

      <div class="card-grid card-grid-projects">
        {featuredProjects.slice(0, 4).map((item) => <ProjectCard item={item} compact={true} />)}
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container">
      <SectionHeader
        eyebrow="CAPABILITIES"
        title="Engineering discipline with business-facing clarity."
        copy="The public profile is strongest where technical depth, documentation, systems thinking and execution meet."
      />

      <div class="card-grid card-grid-2">
        {skillClusters.map((cluster) => <SkillCluster cluster={cluster} />)}
      </div>
    </div>
  </section>

  <section class="section-shell section-shell-last">
    <div class="container">
      <CTASection
        eyebrow="NEXT PATHWAY"
        title="Open the right layer."
        body="Use Experience for formal context, Projects for technical depth, Alpha Signature for consulting and Cyrus for the institutional bridge."
        actions={[
          { label: "View Experience", href: "/experience/", variant: "primary" },
          { label: "Open Contact", href: "/contact/", variant: "secondary" },
          { label: "GitHub", href: "https://github.com/OBaruch", variant: "ghost", external: true },
        ]}
      />
    </div>
  </section>
</BaseLayout>
