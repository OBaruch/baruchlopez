---
import CTASection from "@/components/CTASection.astro";
import ContextNav from "@/components/ContextNav.astro";
import LinkButton from "@/components/LinkButton.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import {
  featuredProjects,
  projectArchiveGroups,
  projectCategories,
} from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";

const projectsGuide = [
  { label: "How to read", href: "#projects-read", note: "Start with the logic" },
  { label: "Taxonomy", href: "#projects-taxonomy", note: "See the categories" },
  { label: "Featured", href: "#projects-featured", note: "Open the curated set" },
  { label: "Archive", href: "#projects-archive", note: "Review the broader groups" },
];
---

<BaseLayout
  title="Projects / Project Lab | Baruch López"
  description="A curated project lab spanning robotics, AI, automation, finance experiments and selected public repositories."
  currentPath={Astro.url.pathname}
  canonicalPath="/projects/"
>
  <section class="hero-shell hero-shell-text">
    <div class="container hero-grid">
      <div class="hero-copy reveal-enter">
        <span class="eyebrow">PROJECT LAB</span>
        <h1>Project Lab</h1>
        <p class="hero-intro">
          Experiments, systems and technical evolution across AI, robotics, automation, finance and software.
        </p>
        <p class="hero-body">
          The lab is organized to show progress and range while keeping prototypes, archives and
          finished work clearly distinguished.
        </p>

        <div class="button-row">
          <LinkButton label="Jump to featured work" href="#projects-featured" variant="primary" />
          <LinkButton label="Open GitHub" href="https://github.com/OBaruch" variant="ghost" external={true} />
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell section-shell-tight">
    <div class="container">
      <ContextNav
        title="A guided archive, not a repository dump."
        copy="The lab separates the strongest public projects from the wider archive and from work that should remain carefully framed."
        items={projectsGuide}
      />
    </div>
  </section>

  <section class="section-shell" id="projects-read">
    <div class="container">
      <SectionHeader
        eyebrow="HOW TO READ THIS PAGE"
        title="Three layers, three different reading depths."
        copy="Featured work, archive groups and careful framing make the project story easier to scan."
      />

      <div class="card-grid card-grid-3">
        <article class="panel reveal-enter">
          <h3>Featured work</h3>
          <p>Start here for the strongest public projects with the clearest narrative value and technical signal.</p>
        </article>
        <article class="panel reveal-enter">
          <h3>Archive groups</h3>
          <p>Use the archive blocks to understand range without forcing every historical experiment into the spotlight.</p>
        </article>
        <article class="panel reveal-enter">
          <h3>Careful framing</h3>
          <p>Some entries stay high level when the work touches private, corporate or finance-adjacent context.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-shell" id="projects-taxonomy">
    <div class="container">
      <SectionHeader
        eyebrow="TAXONOMY"
        title="How to read the lab."
        copy="These categories organize the archive without pretending to be a strict product catalog."
      />

      <div class="tag-list tag-list-wide" aria-label="Project categories">
        {projectCategories.map((item) => <span class="tag">{item}</span>)}
      </div>
    </div>
  </section>

  <section class="section-shell" id="projects-featured">
    <div class="container">
      <SectionHeader
        eyebrow="FEATURED PROJECTS"
        title="Selected public-facing work."
        copy="Each project is shown with context, status and careful framing when it touches corporate or finance-adjacent themes."
      />

      <div class="card-grid card-grid-projects">
        {featuredProjects.map((item) => <ProjectCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="section-shell" id="projects-archive">
    <div class="container">
      <SectionHeader
        eyebrow="ARCHIVE GROUPS"
        title="The broader technical archive."
        copy="These groups summarize the systems and experiments that shaped the profile without forcing every repository into equal prominence."
      />

      <div class="card-grid card-grid-3">
        {
          projectArchiveGroups.map((item) => (
            <article class="panel reveal-enter">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell section-shell-last">
    <div class="container">
      <CTASection
        eyebrow="EXTERNAL REFERENCE"
        title="Use GitHub for the wider public archive."
        body="The website curates the narrative. GitHub carries repository depth, while Experience shows the formal professional layer connected to this work."
        actions={[
          { label: "Open GitHub", href: "https://github.com/OBaruch", variant: "primary", external: true },
          { label: "View Experience", href: "/experience/", variant: "secondary" },
        ]}
      />
    </div>
  </section>
</BaseLayout>
